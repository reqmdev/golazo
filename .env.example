# Copy to hosting panel as Environment Variables (do not commit .env).

CLIENT_TOKEN=your_bot_token_here
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/golazo?retryWrites=true&w=majority

# Production: leave GOLAZO_DEV_MODE unset or false for global slash commands
GOLAZO_DEV_MODE=false
GOLAZO_DEV_GUILD_ID=

# Bot owner / developers (required for owner-only commands)
GOLAZO_OWNER_ID=your_discord_user_id
GOLAZO_DEVELOPER_IDS=

# Developer slash commands (/eval, /admin, /reload) — disabled unless true
GOLAZO_ENABLE_DEV_COMMANDS=false

# Prefix message commands (requires Message Content intent when true)
GOLAZO_MESSAGE_COMMANDS=false

# Optional: Discord webhook for uncaught errors (production monitoring)
GOLAZO_ERROR_WEBHOOK=

# Render engine: svg (default) or canvas
RENDER_ENGINE=svg

# Audit log retention in seconds (default 1 year). Set 0 to disable TTL index.
GOLAZO_AUDIT_TTL_SECONDS=31536000

# Force-disable MongoDB transactions on replica sets (testing only)
# GOLAZO_DISABLE_TRANSACTIONS=true

# Health HTTP port. Cloud (Render/Railway/Fly) uses injected PORT automatically.
# Set GOLAZO_HEALTH_PORT only for local/Docker override.
# GOLAZO_HEALTH_PORT=8080

# Log format: text (default) or json
GOLAZO_LOG_FORMAT=json

# In-memory cache bounds (LRU + periodic sweep)
# GOLAZO_PREFIX_CACHE_MAX=5000
# GOLAZO_USER_LOCALE_CACHE_MAX=10000
# GOLAZO_GUILD_LOCALE_CACHE_MAX=5000
# GOLAZO_CACHE_SWEEP_MS=300000
# GOLAZO_INTERACTION_GUARD_MAX=10000

# Render/dashboard component rate limit (per user, per namespace)
GOLAZO_RENDER_RATE_LIMIT_ENABLED=true
GOLAZO_RENDER_RATE_LIMIT=12
GOLAZO_RENDER_RATE_WINDOW_MS=60000

# When the bot leaves a guild: cache_only (default), archive, or delete
GOLAZO_GUILD_LEAVE_DATA_POLICY=cache_only

# Optional: run via src/sharding/manager.js (npm run start:sharded)
# GOLAZO_SHARD_COUNT=auto

# Incremental standings after score submit (off by default; no head_to_head leagues)
GOLAZO_INCREMENTAL_STANDINGS=false

# GET /metrics on the health port (Prometheus text format)
# Scraped automatically when GOLAZO_HEALTH_PORT is set